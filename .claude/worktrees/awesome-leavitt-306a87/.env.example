# ─── App ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64
JWT_EXPIRES_IN=8h

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://sysops:sysops_pass@localhost:5432/sysops_hub

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Demo Mode (no integrations needed) ────────────────────────────
DEMO_MODE=true

# ─── Connectors (set DEMO_MODE=false to use these) ─────────────────
# Zabbix
ZABBIX_URL=http://zabbix.internal/zabbix
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix

# Uptime Kuma
UPTIME_KUMA_URL=http://uptime.internal
UPTIME_KUMA_API_KEY=

# Proxmox
PROXMOX_URL=https://proxmox.internal:8006
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=
PROXMOX_VERIFY_SSL=false

# vCenter
VCENTER_URL=https://vcenter.internal
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=

# Portainer
PORTAINER_URL=http://portainer.internal:9000
PORTAINER_API_KEY=

# NAS (Synology DSM API)
NAS_URL=http://nas.internal:5000
NAS_USER=admin
NAS_PASSWORD=

# ─── Notifications ──────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ─── Entra ID SSO (opcional, dejar vacío para auth local) ──────────
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=http://localhost:3001/auth/entra/callback
